# =============================================================================
# VT Gas & Market — standalone deployment environment variables
# =============================================================================
# Use this file as the source of truth once the app is off Lovable Cloud.
# Frontend vars are exposed to the browser (Vite `import.meta.env.VITE_*`).
# Backend vars are read only by Vercel serverless functions under /api.

# ------------- Frontend (Vite build-time) -------------
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_GOOGLE_MAPS_BROWSER_KEY=
VITE_GOOGLE_MAPS_TRACKING_ID=

# ------------- Backend: Supabase (Vercel functions) -------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWKS=

# ------------- Backend: Google Drive + Sheets (OAuth user-refresh flow) -------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHEET_ID=

# ------------- Backend: Email (Resend) -------------
RESEND_API_KEY=
HIRING_EMAIL=vtgmhr@gmail.com

# =============================================================================
# Removed on migration off Lovable Cloud:
#   LOVABLE_API_KEY                                 (Lovable AI Gateway — unused)
#   GOOGLE_SERVICE_ACCOUNT_JSON                     (unused — OAuth refresh token is used instead)
#   VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_BROWSER_KEY  (renamed → VITE_GOOGLE_MAPS_BROWSER_KEY)
#   VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_TRACKING_ID  (renamed → VITE_GOOGLE_MAPS_TRACKING_ID)
# =============================================================================
